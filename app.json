{
  "expo": {
    "name": "sonic",
    "slug": "sonic",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sonic",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "buildNumber": "4"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F2B",
        "foregroundImage": "./assets/images/icon.png"
      },
      "versionCode": 4,
      "package": "com.itsishandev.sonic"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/7cefc623-c5dc-4d02-8a7f-af9d2865e177",
      "enabled": true,
      "checkAutomatically": "OFF"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7cefc623-c5dc-4d02-8a7f-af9d2865e177"
      }
    }
  }
}